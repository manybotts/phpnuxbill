# PHPNuxBill /system protection for Koyeb.
# Deny direct web access to PHP files inside /system, except api.php.
# cron.php is intentionally NOT public; run it through /cron-run.php with CRON_SECRET.

<FilesMatch "^(?!api\.php$).+\.php$">
    Require all denied
</FilesMatch>

<Files "api.php">
    Require all granted
</Files>
